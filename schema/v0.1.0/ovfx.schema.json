{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/openperimetry/ovfx-spec/main/schema/v0.1.0/ovfx.schema.json",
  "title": "OVFX — Open Visual Field eXchange",
  "description": "JSON Schema for OVFX v0.1.0 perimetry result documents. See spec/v0.1.0.md for the normative specification.",
  "type": "object",
  "required": ["ovfxVersion", "id", "createdAt", "test", "calibration", "stimuli", "points"],
  "additionalProperties": false,
  "properties": {
    "ovfxVersion": {
      "type": "string",
      "pattern": "^0\\.1\\.[0-9]+$",
      "description": "Semantic version of the OVFX specification this document conforms to."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Globally unique identifier for this result. UUIDv4 recommended."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp of when the test was performed."
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anonymousId": { "type": "string", "minLength": 1 },
        "birthYear": { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "sex": { "type": "string", "enum": ["male", "female", "other", "unknown"] }
      }
    },
    "test": {
      "type": "object",
      "required": ["type", "eye"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["kinetic", "static", "ring"] },
        "eye": { "type": "string", "enum": ["left", "right", "both"] },
        "extendedField": { "type": "boolean" },
        "binocularGroup": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "maxLength": 2000 }
      }
    },
    "calibration": {
      "type": "object",
      "required": [
        "viewingDistanceCm",
        "pixelsPerDegree",
        "screenWidthPx",
        "screenHeightPx",
        "fixationOffsetPx",
        "maxEccentricityDeg"
      ],
      "additionalProperties": false,
      "properties": {
        "viewingDistanceCm": { "type": "number", "exclusiveMinimum": 0 },
        "pixelsPerDegree": { "type": "number", "exclusiveMinimum": 0 },
        "screenWidthPx": { "type": "number", "exclusiveMinimum": 0 },
        "screenHeightPx": { "type": "number", "exclusiveMinimum": 0 },
        "fixationOffsetPx": { "type": "number" },
        "maxEccentricityDeg": { "type": "number", "exclusiveMinimum": 0 },
        "brightnessFloor": { "type": "number", "minimum": 0, "maximum": 1 },
        "reactionTimeMs": { "type": "number", "minimum": 0 }
      }
    },
    "stimuli": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "sizeDeg", "intensity"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "sizeDeg": { "type": "number", "exclusiveMinimum": 0 },
          "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{3,8}$" },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stimulusKey", "meridianDeg", "eccentricityDeg", "detected"],
        "properties": {
          "stimulusKey": { "type": "string", "minLength": 1 },
          "meridianDeg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
          "eccentricityDeg": { "type": "number", "minimum": 0 },
          "detected": { "type": "boolean" },
          "rawEccentricityDeg": { "type": "number", "minimum": 0 },
          "responseTimeMs": { "type": "number", "minimum": 0 },
          "sectorIdx": { "type": "integer", "minimum": 0 },
          "repeat": { "type": "boolean" }
        },
        "patternProperties": {
          "^_": {}
        },
        "additionalProperties": false
      }
    },
    "isopters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stimulusKey", "areaSqDeg"],
        "additionalProperties": false,
        "properties": {
          "stimulusKey": { "type": "string", "minLength": 1 },
          "areaSqDeg": { "type": "number", "minimum": 0 }
        }
      }
    },
    "software": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Implementation-defined extensions, namespaced by reverse-DNS keys.",
      "additionalProperties": true
    }
  }
}
